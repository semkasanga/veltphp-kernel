{
    "name": "velt/kernel",
    "description": "Core kernel contracts and foundation for the Velt framework.",
    "type": "library",
    "license": "MIT",

    "require": {
        "php": "^8.2",
        "velt/ui": "*"
    },

    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/semkasanga/velt-ui.git"
        }
    ],

    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },

    "autoload": {
        "psr-4": {
            "Velt\\Kernel\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Velt\\Kernel\\Tests\\": "tests/"
        }
    },

    "scripts": {
        "test": "phpunit"
    },

    "minimum-stability": "dev",
    "prefer-stable": true
}
