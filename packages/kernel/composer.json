{
    "name": "velt/kernel",
    "description": "Core kernel contracts and foundation for the Velt framework.",
    "type": "library",
    "license": "MIT",

    "require": {
        "php": "^8.2"
    },

    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/semkasanga/velt-ui.git"
        }
    ],

    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95",
        "rector/rector": "^2.4"
    },

    "autoload": {
        "psr-4": {
            "Velt\\Kernel\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Velt\\Kernel\\Tests\\": "tests/"
        }
    },

    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "rector:dry-run": "rector process --dry-run",
        "rector:fix": "rector process",
        "quality": [
            "@analyse",
            "@cs:check"
        ]
    },

    "minimum-stability": "dev",
    "prefer-stable": true
}
